{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://shanurl.onrender.com/api/$1"
    },
    {
      "src": "/r/(.*)",
      "dest": "https://shanurl.onrender.com/r/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
