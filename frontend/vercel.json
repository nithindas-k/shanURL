{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://YOUR_BACKEND_RENDER_URL/api/$1"
    },
    {
      "src": "/r/(.*)",
      "dest": "https://YOUR_BACKEND_RENDER_URL/r/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
